    "openclaw": ">=2026.7.1-2"
  },
  "devDependencies": {
    "openclaw": "2026.7.1-2",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0",
    "@types/node": "^22.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
